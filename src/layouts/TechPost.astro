---
import type { CollectionEntry } from "astro:content";
import type { MarkdownHeading } from "astro";
import BaseLayout from "./BaseLayout.astro";
import FormattedDate from "../components/FormattedDate.astro";
import TableOfContents from "../components/TableOfContents.astro";
import { Icon } from "astro-icon/components";
import {
  TECH_CATEGORY_META_LIST,
  getBlogTagMeta,
  DEFAULT_TAG_META,
} from "../consts";

type Props = CollectionEntry<"blog">["data"] & {
  headings?: MarkdownHeading[];
};

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  techCategory,
  tags = [],
  headings = [],
} = Astro.props;

const categoryMeta = TECH_CATEGORY_META_LIST.find(
  (item) => item.key === techCategory,
);
---

<BaseLayout title={title} description={description}>
  <div class="relative w-full">
    <aside
      class="toc-scroll hidden xl:block fixed top-32 left-[calc(50%+26rem)] w-72 h-[calc(100vh-10rem)] overflow-y-auto overflow-x-hidden overscroll-contain z-10 opacity-80 hover:opacity-100 transition-opacity duration-300"
      data-lenis-prevent
    >
      <TableOfContents headings={headings} />
    </aside>

    <article
      class="py-6 md:py-16 w-full max-w-4xl mx-auto px-3 md:px-6 relative z-0"
    >
      <header class="mb-8 md:mb-12">
        <a
          href="/"
          class="inline-flex items-center gap-2 text-ink-500 hover:text-vermilion transition-all mb-6 text-sm tracking-widest uppercase group active:scale-95"
        >
          <Icon
            name="mingcute:arrow-left-line"
            class="group-hover:-translate-x-1 transition-transform"
          />
          <span>Return</span>
        </a>

        <div class="flex flex-wrap items-center gap-2 mb-4">
          <span
            class="inline-flex items-center gap-1 text-xs font-semibold tracking-widest uppercase px-2 py-1 rounded border border-ink-300 text-ink-700 dark:border-zinc-600 dark:text-zinc-300"
          >
            <Icon
              name={categoryMeta?.icon || "mingcute:book-2-line"}
              class="w-4 h-4"
            />
            {categoryMeta?.label || "技术学习"}
          </span>

          {
            tags.map((tag) => {
              const tagMeta = getBlogTagMeta(tag);
              const token = tagMeta.styleToken || DEFAULT_TAG_META.styleToken;

              return (
                <span
                  class={`tag-pill inline-flex items-center gap-1 text-xs font-medium px-2 py-1 rounded border tag-token-${token}`}
                >
                  <Icon name={tagMeta.icon} class="w-4 h-4" />
                  {tagMeta.label}
                </span>
              );
            })
          }
        </div>

        <h1
          class="text-3xl md:text-5xl font-bold text-ink-900 dark:text-zinc-100 leading-tight tracking-tight"
        >
          {title}
        </h1>

        <div
          class="mt-4 flex flex-wrap items-center gap-3 text-sm text-ink-500 dark:text-zinc-400 uppercase tracking-widest"
        >
          <FormattedDate date={pubDate} />
          {
            updatedDate && (
              <span class="inline-flex items-center gap-1">
                <Icon name="mingcute:refresh-2-line" class="w-4 h-4" />
                Updated <FormattedDate date={updatedDate} />
              </span>
            )
          }
        </div>
      </header>

      {
        heroImage && (
          <div class="w-full mb-10 md:mb-14 group">
            <img
              src={heroImage.src}
              alt={title}
              loading="eager"
              decoding="async"
              class="w-full h-auto object-cover rounded-sm shadow-ink transition-transform duration-500 md:group-hover:scale-[1.01]"
            />
          </div>
        )
      }

      {
        headings.length > 0 && (
          <div class="xl:hidden mb-6">
            <details class="bg-ink-50 dark:bg-zinc-800/50 rounded-sm border border-ink-200 dark:border-zinc-700 group">
              <summary class="p-4 font-bold text-ink-900 dark:text-zinc-100 cursor-pointer flex items-center justify-between list-none select-none">
                <div class="flex items-center gap-2">
                  <Icon
                    name="mingcute:list-check-line"
                    class="w-5 h-5 text-vermilion"
                  />
                  <span>Table of Contents</span>
                </div>
                <Icon
                  name="mingcute:down-line"
                  class="w-5 h-5 transition-transform duration-300 group-open:rotate-180 text-ink-400"
                />
              </summary>
              <div class="px-4 pb-4 pt-4 border-t border-ink-200/50 dark:border-zinc-700/50">
                <TableOfContents headings={headings} />
              </div>
            </details>
          </div>
        )
      }

      <div class="prose prose-sm md:prose-base prose-ink max-w-none">
        <slot />
      </div>
    </article>
  </div>

  {/* --- 代码块功能：图标库模板 --- */}
  <template id="code-icon-template">
    {/* macOS 风格的图标 */}
    <div data-icon="mac-copy"><Icon name="mingcute:copy-fill" /></div>
    <div data-icon="mac-success"><Icon name="mingcute:check-fill" /></div>
    <div data-icon="mac-expand"><Icon name="mingcute:down-fill" /></div>
    <div data-icon="mac-collapse"><Icon name="mingcute:up-fill" /></div>
    <div data-icon="mac-theme"><Icon name="mingcute:coathanger-fill" /></div>

    {/* 水墨风的图标 */}
    <div data-icon="ink-copy">
      <Icon name="material-symbols:content-copy-outline-sharp" />
    </div>
    <div data-icon="ink-success"><Icon name="material-symbols:check" /></div>
    <div data-icon="ink-expand">
      <Icon name="material-symbols:expand-all" />
    </div>
    <div data-icon="ink-collapse">
      <Icon name="material-symbols:collapse-all" />
    </div>
    <div data-icon="ink-theme">
      <Icon name="material-symbols:palette-outline" />
    </div>
  </template>

  {/* --- 代码块功能：水墨风操作栏模板 --- */}
  <template id="ink-action-template">
    <div
      class="ink-actions-container absolute -top-9 right-1 z-30 hidden flex-row-reverse items-center -gap-1 md:gap-2 group"
    >
      {/* 印章：作为悬浮操作栏的触发器 */}
      <div
        class="ink-seal-trigger relative w-8 h-8 shrink-0 cursor-pointer md:cursor-default"
      >
        <div
          class="absolute inset-0 bg-ink-900 dark:bg-zinc-100 rounded-[40%_60%_70%_30%/40%_50%_60%_50%] animate-[spin_8s_linear_infinite] transition-all duration-500 group-hover:scale-110 group-hover:bg-vermilion/60"
        >
        </div>
        <div
          class="absolute inset-1 bg-ink-700 dark:bg-zinc-300 rounded-[60%_40%_30%_70%/60%_30%_70%_40%] animate-[spin_12s_linear_infinite_reverse] transition-all duration-500 group-hover:bg-vermilion"
        >
        </div>
        <div
          class="absolute inset-0 flex items-center justify-center text-zinc-100 dark:text-zinc-800 transition-colors duration-300 group-hover:text-white z-10 font-serif text-xs font-bold select-none cursor-default"
        >
          P
        </div>
      </div>

      {/* 操作栏：包含复制、主题切换、折叠等功能 */}
      <div
        class="ink-scroll-panel flex items-center gap-1 md:gap-4 overflow-hidden max-w-0 opacity-0 md:group-hover:max-w-[200px] md:group-hover:opacity-100 md:group-hover:px-4 transition-all duration-500 ease-[cubic-bezier(0.19,1,0.22,1)] bg-transparent"
      >
        {/* 主题切换按钮 */}
        <button
          class="ink-action-btn ink-theme-btn text-ink-600 dark:text-zinc-400 opacity-70 hover:opacity-100 hover:scale-110 hover:-translate-y-0.5 hover:text-vermilion dark:hover:text-vermilion drop-shadow-sm hover:drop-shadow-md transition-all duration-300 transform-gpu will-change-transform"
          title="切换回 macOS 风格"></button>

        {/* 复制代码按钮 */}
        <button
          class="ink-action-btn ink-copy-btn text-ink-600 dark:text-zinc-400 opacity-70 hover:opacity-100 hover:scale-110 hover:-translate-y-0.5 hover:text-vermilion dark:hover:text-vermilion drop-shadow-sm hover:drop-shadow-md transition-all duration-300 transform-gpu will-change-transform"
          title="复制代码"></button>

        {/* 复制成功状态指示 */}
        <span
          class="ink-copy-success w-7 h-7 text-vermilion hidden items-center justify-center drop-shadow-md scale-110 transform-gpu"
        ></span>

        {/* 折叠/展开按钮 */}
        <button
          class="ink-action-btn ink-toggle-btn text-ink-600 dark:text-zinc-400 opacity-70 hover:opacity-100 hover:scale-110 hover:-translate-y-0.5 hover:text-vermilion dark:hover:text-vermilion drop-shadow-sm hover:drop-shadow-md transition-all duration-300 transform-gpu will-change-transform"
          title="折叠/展开"></button>
      </div>
    </div>
  </template>
</BaseLayout>

