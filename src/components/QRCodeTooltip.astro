---
// src/components/QRCodeTooltip.astro
import { Icon } from "astro-icon/components";

interface Props {
  url: string;
  qrUrl?: string | null;
  icon: string;
  label: string;
  message: string;
}

const { url, qrUrl, icon, label, message } = Astro.props;
---

<div class="relative group/qr">
  {/* Icon 永远保持高亮可点状态 */}
  <a
    href={url}
    target="_blank"
    rel="noopener noreferrer"
    aria-label={label}
    class="block text-ink-300 dark:text-zinc-500 transition-all duration-300 hover:text-vermilion hover:scale-110 active:text-vermilion active:scale-90"
  >
    <Icon name={icon} class="w-5 h-5" />
  </a>

  {/* 悬浮气泡：根据传入的 qrUrl 决定是否渲染 Canvas */}
  <div
    class="qr-tooltip absolute bottom-full left-1/2 -translate-x-1/2 mb-3 p-3 bg-white dark:bg-zinc-800 backdrop-blur-sm rounded-lg shadow-xl border border-ink-100/5 transition-all duration-300 opacity-0 translate-y-2 pointer-events-none group-hover/qr:opacity-100 group-hover/qr:translate-y-0 flex flex-col items-center w-max min-w-[110px]"
  >
    {
      qrUrl && (
        <div class="bg-white p-1.5 rounded mb-2 shadow-sm shrink-0">
          <canvas class="w-20 h-20" data-qr-url={qrUrl} />
        </div>
      )
    }

    {
      /* 提示文字：如果有二维码颜色深一点，如果没有二维码（纯文字）颜色稍微柔和一点 */
    }
    <p
      class={`text-[11px] font-sans text-center leading-tight whitespace-nowrap ${qrUrl ? "text-ink-700 dark:text-zinc-400" : "text-ink-500 dark:text-zinc-500"}`}
    >
      {message}
    </p>

    <div
      class="absolute top-full left-1/2 -translate-x-1/2 border-8 border-transparent border-t-white dark:border-t-zinc-800"
    >
    </div>
  </div>
</div>
