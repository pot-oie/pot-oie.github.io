---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();
---

<footer class="mt-auto border-t border-zinc-200 dark:border-zinc-800 py-8">
  <div class="max-w-6xl mx-auto px-4 text-center text-zinc-500">
    <p>
      &copy; {currentYear} Pot. All rights reserved.
    </p>
    <p class="mt-2 text-sm">
      Powered by <a
        href="https://astro.build/"
        target="_blank"
        class="underline hover:text-primary-500">Astro</a
      >
      & <a
        href="https://github.com/pot-oie/pot-oie.github.io"
        target="_blank"
        class="underline hover:text-primary-500">GitHub</a
      >
    </p>
    <p
      class="mt-2 text-xs flex flex-wrap items-center justify-center gap-x-4 gap-y-1"
    >
      <a
        href="https://beian.miit.gov.cn/"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-primary-500">粤ICP备2026024269号</a
      >
      <a
        href="https://beian.mps.gov.cn/#/query/webSearch?code=44030002011898"
        target="_blank"
        rel="noreferrer"
        class="inline-flex items-center gap-1 hover:text-primary-500"
      >
        <img
          src="/docs/beian.png"
          alt="公安备案图标"
          class="inline-block h-3.5 w-3.5"
        />
        粤公网安备44030002011898号
      </a>
    </p>
  </div>
</footer>
