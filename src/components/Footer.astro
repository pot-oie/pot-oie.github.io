---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();
---

<footer class="mt-auto border-t border-zinc-200 dark:border-zinc-800 py-8">
  <div class="max-w-6xl mx-auto px-4 text-center text-zinc-500">
    <p>
      &copy; {currentYear} Pot. All rights reserved.
    </p>
    <p class="mt-2 text-sm">
      Powered by <a
        href="https://astro.build/"
        target="_blank"
        class="underline hover:text-primary-500">Astro</a
      >
      & <a
        href="https://github.com/pot-oie/pot-oie.github.io"
        target="_blank"
        class="underline hover:text-primary-500">GitHub</a
      >
    </p>
    <p class="mt-2 text-xs">
      <a
        href="https://beian.miit.gov.cn/"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-primary-500">粤ICP备2026024269号</a
      >
    </p>
  </div>
</footer>
