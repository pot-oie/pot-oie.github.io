---
import type { MarkdownHeading } from "astro";
import { Icon } from "astro-icon/components";
import type { SeriesNavData } from "./SeriesNavigation.astro";

type Props = {
  headings: MarkdownHeading[];
  series?: SeriesNavData;
};

const { headings, series } = Astro.props;
const tocItems = headings.filter(
  (heading) => heading.depth > 1 && heading.depth <= 3,
);
const seriesItems = series?.items ?? [];
const seriesSections = series?.sections?.length
  ? series.sections
  : [{ title: "未分组", order: Number.MAX_SAFE_INTEGER, items: seriesItems }];
const hasSeries = seriesItems.length > 1;
const hasToc = tocItems.length > 0;
const triggerGridClass = hasSeries && hasToc ? "grid-cols-2" : "grid-cols-1";
---

{
  (hasSeries || hasToc) && (
    <section
      class="mobile-reading-nav xl:hidden mb-6 overflow-hidden rounded-sm border border-ink-200/70 bg-stone-50/80 font-sans backdrop-blur-[2px] dark:border-zinc-700/70 dark:bg-zinc-800/50"
      data-mobile-reading-nav
      data-pagefind-ignore
    >
      <div
        class:list={[
          "grid border-b border-ink-200/60 dark:border-zinc-700/70",
          triggerGridClass,
        ]}
      >
        {hasSeries && (
          <button
            type="button"
            id="mobile-series-trigger"
            class="mobile-reading-trigger flex items-center justify-center gap-2 px-4 py-3 text-sm font-bold text-ink-700 transition-colors duration-200 dark:text-zinc-300"
            data-mobile-panel-trigger="series"
            aria-controls="mobile-series-panel"
            aria-expanded="false"
          >
            <Icon name="mingcute:route-line" class="h-5 w-5 text-vermilion" />
            <span>导览</span>
          </button>
        )}

        {hasToc && (
          <button
            type="button"
            id="mobile-toc-trigger"
            class:list={[
              "mobile-reading-trigger flex items-center justify-center gap-2 px-4 py-3 text-sm font-bold text-ink-700 transition-colors duration-200 dark:text-zinc-300",
              hasSeries && "border-l border-ink-200/60 dark:border-zinc-700/70",
            ]}
            data-mobile-panel-trigger="toc"
            aria-controls="mobile-toc-panel"
            aria-expanded="false"
          >
            <Icon name="mingcute:list-check-line" class="h-5 w-5 text-vermilion" />
            <span>目录</span>
          </button>
        )}
      </div>

      {hasSeries && series && (
        <div
          id="mobile-series-panel"
          class="mobile-reading-panel toc-scroll side-scroll-fade max-h-[60vh] overflow-y-auto overflow-x-hidden px-3 py-3"
          data-mobile-panel="series"
          data-lenis-prevent
          aria-labelledby="mobile-series-trigger"
        >
          <div class="flex flex-col gap-1.5">
            {seriesSections.map((section) => (
              <details class="mobile-series-section" open>
                <summary class="mobile-series-section-summary flex cursor-pointer select-none items-center justify-between gap-2 rounded-sm bg-white/25 px-2.5 py-2 text-[0.68rem] font-semibold tracking-widest text-ink-500 transition-colors duration-200 hover:bg-white/60 hover:text-vermilion dark:bg-zinc-900/25 dark:text-zinc-400 dark:hover:bg-zinc-800/45 dark:hover:text-vermilion">
                  <span class="flex min-w-0 items-center gap-1.5">
                    <span
                      class="mobile-series-section-icon inline-flex h-4 w-4 shrink-0 items-center justify-center text-ink-400 transition-colors duration-200 dark:text-zinc-500"
                      aria-hidden="true"
                    >
                      <Icon
                        name="mingcute:down-fill"
                        class="mobile-series-section-icon-open h-3.5 w-3.5"
                      />
                      <Icon
                        name="mingcute:up-fill"
                        class="mobile-series-section-icon-closed hidden h-3.5 w-3.5"
                      />
                    </span>
                    <span class="min-w-0 truncate">{section.title}</span>
                  </span>
                  <span
                    class="mobile-series-section-count shrink-0 rounded-full bg-ink-100/55 px-1.5 py-0.5 text-[0.58rem] font-semibold leading-none tracking-normal text-ink-400 dark:bg-zinc-800/55 dark:text-zinc-500"
                    aria-label={`${section.items.length} 篇文章`}
                  >
                    {section.items.length}
                  </span>
                </summary>
                <ol class="mobile-series-section-items flex flex-col gap-0.5 pt-1.5">
                  {section.items.map((item) => {
                    const subtitle = item.subtitle?.trim() ?? "";
                    const accessibleTitle = subtitle || item.title;

                    return (
                      <li>
                        <a
                          href={item.href}
                          aria-current={item.current ? "page" : undefined}
                          aria-label={`${section.title} ${item.order}. ${accessibleTitle}`}
                          title={accessibleTitle}
                          class:list={[
                            "mobile-reading-link group grid grid-cols-[1.25rem_minmax(0,1fr)] items-center gap-3 rounded-sm px-2.5 py-2 text-sm leading-tight text-balance wrap-break-word whitespace-normal transition-colors duration-200",
                            item.current
                              ? "is-current font-semibold text-ink-900 dark:text-zinc-100"
                              : "text-ink-500 hover:text-vermilion dark:text-zinc-500 dark:hover:text-vermilion",
                          ]}
                        >
                          <span
                            class:list={[
                              "mobile-reading-number flex h-5 w-5 items-center justify-center text-xs font-semibold tabular-nums transition-colors duration-200",
                              item.current
                                ? "rounded-full bg-vermilion text-white"
                                : "text-ink-400 group-hover:text-vermilion dark:text-zinc-500 dark:group-hover:text-vermilion",
                            ]}
                          >
                            {item.order}
                          </span>
                          <span class="min-w-0 truncate">{accessibleTitle}</span>
                        </a>
                      </li>
                    );
                  })}
                </ol>
              </details>
            ))}
          </div>
        </div>
      )}

      {hasToc && (
        <div
          id="mobile-toc-panel"
          class="mobile-reading-panel toc-scroll side-scroll-fade max-h-[60vh] overflow-y-auto overflow-x-hidden px-3 py-3"
          data-mobile-panel="toc"
          data-lenis-prevent
          aria-labelledby="mobile-toc-trigger"
        >
          <ol class="flex flex-col gap-0.5">
            {tocItems.map((heading) => (
              <li style={`padding-left: ${(heading.depth - 2) * 0.75}rem`}>
                <a
                  href={`#${heading.slug}`}
                  data-slug={heading.slug}
                  title={heading.text}
                  class="toc-link mobile-reading-link group grid grid-cols-[1.25rem_minmax(0,1fr)] items-center gap-3 rounded-sm px-2.5 py-2 text-sm leading-tight text-ink-500 transition-colors duration-200 hover:text-vermilion dark:text-zinc-500 dark:hover:text-vermilion"
                >
                  <span class="mobile-reading-marker flex h-5 w-5 items-center justify-center text-xs font-semibold text-ink-300 transition-colors duration-200 group-hover:text-vermilion dark:text-zinc-600 dark:group-hover:text-vermilion">
                    {heading.depth === 2 ? "•" : "·"}
                  </span>
                  <span class="min-w-0 truncate">{heading.text}</span>
                </a>
              </li>
            ))}
          </ol>
        </div>
      )}
    </section>
  )
}

<style>
  .mobile-reading-panel {
    display: none;
  }

  .mobile-reading-panel.is-active {
    display: block;
  }

  .mobile-reading-nav[data-active-panel="series"]
    [data-mobile-panel-trigger="series"],
  .mobile-reading-nav[data-active-panel="toc"]
    [data-mobile-panel-trigger="toc"] {
    background: var(--reading-nav-trigger-active-bg);
    color: var(--reading-nav-trigger-active-text);
  }

  .mobile-reading-link.is-current {
    background: var(--reading-nav-current-bg);
  }

  .mobile-series-section > summary {
    list-style: none;
  }

  .mobile-series-section > summary::-webkit-details-marker {
    display: none;
  }

  .mobile-series-section:not([open]) .mobile-series-section-icon-open {
    display: none;
  }

  .mobile-series-section:not([open]) .mobile-series-section-icon-closed {
    display: block;
  }

  .mobile-series-section[open] > .mobile-series-section-summary {
    background: var(--reading-nav-current-bg);
    color: var(--reading-nav-trigger-active-text);
  }

  .mobile-series-section[open] .mobile-series-section-icon {
    color: rgb(var(--color-rgb-vermilion-note) / 0.82);
  }

  .mobile-series-section[open] .mobile-series-section-count {
    background: rgb(var(--color-rgb-vermilion-note) / 0.1);
    color: rgb(var(--color-rgb-vermilion-note) / 0.82);
  }

  .mobile-series-section[open] {
    padding-bottom: 0.375rem;
  }

  .mobile-reading-link:global(.scale-105) {
    transform: none;
  }

  .side-scroll-fade {
    --side-scroll-top-fade: var(--mask-visible-stop);
    --side-scroll-bottom-fade: var(--mask-visible-stop);
    -webkit-mask-image: linear-gradient(
      to bottom,
      var(--side-scroll-top-fade),
      var(--mask-visible-stop) 1.25rem,
      var(--mask-visible-stop) calc(100% - 1.25rem),
      var(--side-scroll-bottom-fade)
    );
    mask-image: linear-gradient(
      to bottom,
      var(--side-scroll-top-fade),
      var(--mask-visible-stop) 1.25rem,
      var(--mask-visible-stop) calc(100% - 1.25rem),
      var(--side-scroll-bottom-fade)
    );
  }

  .side-scroll-fade.has-top-fade {
    --side-scroll-top-fade: transparent;
  }

  .side-scroll-fade.has-bottom-fade {
    --side-scroll-bottom-fade: transparent;
  }
</style>
