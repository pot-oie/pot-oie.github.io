---
// src/components/AlbumSidebar.astro
import { Image } from "astro:assets";

interface Props {
  coverImage?: any;
  albumTitle: string;
  albumArtist: string;
}

const { coverImage, albumTitle, albumArtist } = Astro.props;
---

<div class="flex flex-col gap-6 group" id="album-sidebar-player">
  <div
    class="relative w-full aspect-square rounded-sm overflow-hidden shadow-2xl transition-transform duration-500 group-hover:scale-[1.02]"
  >
    {/* 默认黑白，播放时恢复彩色；PC端初始黑白 (is-bw) */}
    {
      coverImage && (
        <Image
          src={coverImage}
          alt={albumTitle}
          width={480}
          height={480}
          format="webp"
          class="w-full h-full object-cover is-bw contrast-[1.1] brightness-90 md:transition-all md:duration-1000 md:ease-in-out"
          id="sidebar-cover"
        />
      )
    }
    {/* 播放时的水墨晕染滤镜遮罩 */}
    <div
      class="absolute inset-0 bg-linear-to-t from-ink/20 to-transparent opacity-0 transition-opacity duration-1000 pointer-events-none"
      id="sidebar-overlay"
    >
    </div>

    {/* 精致的黑胶唱片装饰 (仅在桌面端显示) */}
    <div
      class="absolute -right-16 top-1/2 -translate-y-1/2 w-32 h-32 bg-zinc-900 rounded-full border-4 border-zinc-800 hidden md:flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-700 -z-10 group-hover:-right-10 overflow-hidden"
    >
      <div
        class="w-full h-full border-10 border-zinc-900 rounded-full animate-[spin_4s_linear_infinite]"
        id="sidebar-disc"
      >
        <div class="w-full h-full border border-zinc-700/30 rounded-full"></div>
      </div>
    </div>
  </div>

  <div class="flex flex-col gap-2 px-1">
    <h3
      class="font-serif font-black text-xl md:text-2xl text-ink-900 dark:text-zinc-100 leading-tight transition-all duration-500"
      id="sidebar-track-title"
    >
      {albumTitle}
    </h3>
    <div class="flex items-center gap-2">
      <span class="w-4 h-px bg-vermilion/40"></span>
      <p
        class="text-[10px] md:text-xs font-sans text-ink-400 dark:text-zinc-500 tracking-[0.3em] uppercase italic"
        id="sidebar-artist"
      >
        {albumArtist}
      </p>
    </div>

    {/* 播放状态提示 */}
    <div
      class="mt-4 flex items-center gap-2 opacity-0 transition-opacity duration-500"
      id="playback-status"
    >
      <div class="flex gap-1 items-center h-3">
        <span
          class="w-0.5 h-full bg-vermilion animate-[music-bar_0.6s_ease-in-out_infinite_alternate]"
        ></span>
        <span
          class="w-0.5 h-1/2 bg-vermilion animate-[music-bar_0.8s_ease-in-out_infinite_alternate]"
        ></span>
        <span
          class="w-0.5 h-3/4 bg-vermilion animate-[music-bar_0.5s_ease-in-out_infinite_alternate]"
        ></span>
      </div>
      <span
        class="text-[10px] text-vermilion font-sans tracking-widest uppercase"
        >Now Playing</span
      >
    </div>
  </div>
</div>

<style>
  @keyframes music-bar {
    0% {
      height: 20%;
    }
    100% {
      height: 100%;
    }
  }
  /* 仅在桌面端应用黑白滤镜 */
  @media (min-width: 768px) {
    .is-bw {
      filter: grayscale(1) contrast(1.1) brightness(0.9);
    }
  }

  /* 过渡效果 */
  #sidebar-cover {
    transition:
      filter 1s ease-in-out,
      box-shadow 0.5s ease-in-out;
    will-change: filter;
  }
</style>

<script>
  function initAlbumSidebar() {
    const cover = document.getElementById(
      "sidebar-cover",
    ) as HTMLImageElement | null;
    const titleEl = document.getElementById("sidebar-track-title");
    const status = document.getElementById("playback-status");
    const disc = document.getElementById("sidebar-disc");

    if (!cover) return;

    // 监听全局状态
    const handleAudioState = (e: any) => {
      const { state } = e.detail;
      // 这里可以按需加入 id 校验，比如判断播放的 id 是否属于这个 Album
      // 如果没有特定的判断逻辑，只要系统在播放，侧边栏就跟着动

      if (state === "playing") {
        cover.classList.remove("is-bw");
        cover.classList.add("shadow-2xl", "shadow-vermilion/20");
        if (titleEl) titleEl.classList.add("text-vermilion");
        if (status) status.classList.remove("opacity-0");
        if (disc) disc.style.animationPlayState = "running";
      } else {
        cover.classList.add("is-bw");
        cover.classList.remove("shadow-vermilion/20");
        if (titleEl) titleEl.classList.remove("text-vermilion");
        if (status) status.classList.add("opacity-0");
        if (disc) disc.style.animationPlayState = "paused";
      }
    };

    // 每次进入页面，先解绑上一次可能残留的监听，再重新绑定
    window.removeEventListener("pot:audio-state", handleAudioState);
    window.addEventListener("pot:audio-state", handleAudioState);
  }

  document.addEventListener("astro:page-load", initAlbumSidebar);
</script>
