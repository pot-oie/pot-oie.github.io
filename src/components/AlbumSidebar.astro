---
// src/components/AlbumSidebar.astro
import { Image } from "astro:assets";

interface Props {
  coverImage?: any;
  albumTitle: string;
  albumArtist: string;
}

const { coverImage, albumTitle, albumArtist } = Astro.props;
---

<div class="flex flex-col gap-6 group" id="album-sidebar-player">
  <div class="relative w-full aspect-square rounded-sm overflow-hidden shadow-2xl transition-transform duration-500 group-hover:scale-[1.02]">
    {/* 隐藏的音频元素 */}
    <audio id="sidebar-audio" preload="none"></audio>

    {/* 默认黑白，播放时恢复彩色；PC端初始黑白 (is-bw) */}
    {coverImage && (
      <Image
        src={coverImage}
        alt={albumTitle}
        width={480}
        height={480}
        format="webp"
        class="w-full h-full object-cover is-bw contrast-[1.1] brightness-90 md:transition-all md:duration-1000 md:ease-in-out"
        id="sidebar-cover"
      />
    )}
    {/* 播放时的水墨晕染滤镜遮罩 */}
    <div class="absolute inset-0 bg-linear-to-t from-ink/20 to-transparent opacity-0 transition-opacity duration-1000 pointer-events-none" id="sidebar-overlay"></div>
    
    {/* 精致的黑胶唱片装饰 (仅在桌面端显示) */}
    <div class="absolute -right-16 top-1/2 -translate-y-1/2 w-32 h-32 bg-zinc-900 rounded-full border-4 border-zinc-800 hidden md:flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-700 -z-10 group-hover:-right-10 overflow-hidden">
        <div class="w-full h-full border-10 border-zinc-900 rounded-full animate-[spin_4s_linear_infinite]" id="sidebar-disc">
            <div class="w-full h-full border border-zinc-700/30 rounded-full"></div>
        </div>
    </div>
  </div>

  <div class="flex flex-col gap-2 px-1">
    <h3 class="font-serif font-black text-xl md:text-2xl text-ink-900 dark:text-zinc-100 leading-tight transition-all duration-500" id="sidebar-track-title">
      {albumTitle}
    </h3>
    <div class="flex items-center gap-2">
      <span class="w-4 h-px bg-vermilion/40"></span>
      <p class="text-[10px] md:text-xs font-sans text-ink-400 dark:text-zinc-500 tracking-[0.3em] uppercase italic" id="sidebar-artist">
        {albumArtist}
      </p>
    </div>

    {/* 播放状态提示 */}
    <div class="mt-4 flex items-center gap-2 opacity-0 transition-opacity duration-500" id="playback-status">
        <div class="flex gap-1 items-center h-3">
            <span class="w-0.5 h-full bg-vermilion animate-[music-bar_0.6s_ease-in-out_infinite_alternate]"></span>
            <span class="w-0.5 h-1/2 bg-vermilion animate-[music-bar_0.8s_ease-in-out_infinite_alternate]"></span>
            <span class="w-0.5 h-3/4 bg-vermilion animate-[music-bar_0.5s_ease-in-out_infinite_alternate]"></span>
        </div>
        <span class="text-[10px] text-vermilion font-sans tracking-widest uppercase">Now Playing</span>
    </div>
  </div>
</div>

<style>
  @keyframes music-bar {
    0% { height: 20%; }
    100% { height: 100%; }
  }
  /* 仅在桌面端应用黑白滤镜 */
  @media (min-width: 768px) {
    .is-bw {
      filter: grayscale(1) contrast(1.1) brightness(0.9);
    }
  }

  /* 过渡效果 */
  #sidebar-cover {
    transition: filter 1s ease-in-out, box-shadow 0.5s ease-in-out;
    will-change: filter;
  }
</style>

<script>
  function initAlbumPlayer() {
    const audio = document.getElementById("sidebar-audio") as HTMLAudioElement;
    const cover = document.getElementById("sidebar-cover") as HTMLImageElement;
    const titleEl = document.getElementById("sidebar-track-title");
    const status = document.getElementById("playback-status");
    const disc = document.getElementById("sidebar-disc");
    
    if (!audio) return;

    let currentTrackId: string | null = null;
    let fadeTimer: any = null;
    const targetVolume = 0.4;
    const fadeTime = 800;

    const fadeIn = () => {
      clearInterval(fadeTimer);
      const step = targetVolume / (fadeTime / 20);
      audio.volume = 0;
      fadeTimer = setInterval(() => {
        if (audio.volume + step < targetVolume) {
          audio.volume += step;
        } else {
          audio.volume = targetVolume;
          clearInterval(fadeTimer);
        }
      }, 20);
    };

    const fadeOut = (callback?: () => void) => {
      clearInterval(fadeTimer);
      const step = audio.volume / (fadeTime / 20);
      fadeTimer = setInterval(() => {
        if (audio.volume - step > 0) {
          audio.volume -= step;
        } else {
          audio.volume = 0;
          clearInterval(fadeTimer);
          if (callback) callback();
        }
      }, 20);
    };

    const updateUI = (state: "playing" | "paused" | "ended", title?: string) => {
      if (state === "playing") {
        if (cover) {
          cover.classList.remove("is-bw");
          cover.classList.add("shadow-2xl", "shadow-vermilion/20");
        }
        if (titleEl && title) {
          titleEl.textContent = title;
          titleEl.classList.add("text-vermilion");
        }
        if (status) status.classList.remove("opacity-0");
        if (disc) disc.style.animationPlayState = "running";
      } else {
        if (state === "ended" || state === "paused") {
          if (cover) {
            cover.classList.add("is-bw");
            cover.classList.remove("shadow-vermilion/20");
          }
          if (titleEl) titleEl.classList.remove("text-vermilion");
        }
        
        if (status) status.classList.add("opacity-0");
        if (disc) disc.style.animationPlayState = "paused";
      }
      
      // 发送全局广播，通知所有按钮更新状态
      window.dispatchEvent(new CustomEvent("pot:audio-state", { 
        detail: { id: currentTrackId, state } 
      }));
    };

    audio.addEventListener("play", () => updateUI("playing"));
    audio.addEventListener("pause", () => updateUI("paused"));
    audio.addEventListener("ended", () => {
      // 记录结束前的 ID 用于通知 UI
      const lastId = currentTrackId;
      currentTrackId = null;
      updateUI("ended");
    });

    window.addEventListener("pot:play-request", (e: any) => {
      const { id, url, title } = e.detail;

      if (currentTrackId === id) {
        if (audio.paused) {
          audio.play();
          fadeIn();
        } else {
          // 如果正在播放，先淡出再暂停
          fadeOut(() => {
            audio.pause();
            // 暂停后强制发送一次状态
            updateUI("paused");
          });
        }
        return;
      }

      // 切歌逻辑：如果已经有 src 且不是同一个 ID，说明是切换或初次点击后的第二次操作
      if (audio.src && audio.src !== url) {
        // 先通知旧按钮复位
        if (currentTrackId) {
          window.dispatchEvent(new CustomEvent("pot:audio-state", { 
            detail: { id: currentTrackId, state: "paused" } 
          }));
        }

        fadeOut(() => {
          audio.src = url;
          currentTrackId = id;
          audio.play();
          updateUI("playing", title);
          fadeIn();
        });
      } else {
        // 首次点击或 src 相同但 ID 不同（异常情况处理）
        audio.src = url;
        currentTrackId = id;
        audio.play();
        updateUI("playing", title);
        fadeIn();
      }
    });
  }

  document.addEventListener("astro:page-load", initAlbumPlayer);
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initAlbumPlayer);
  } else {
    initAlbumPlayer();
  }
</script>