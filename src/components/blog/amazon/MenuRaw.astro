---
// src/components/blog/amazon/MenuRaw.astro
---

<div class="modern-menu-wrapper" id="demo-raw">
  <ul class="modern-main-menu">
    <li class="menu-item">
      <span class="menu-label">
        <span class="menu-title">数码产品</span>
        <span class="menu-meta">相机 · 手机 · 配件</span>
      </span>
      <svg class="chevron" viewBox="0 0 20 20" fill="currentColor"
        ><path
          fill-rule="evenodd"
          d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
          clip-rule="evenodd"></path></svg
      >
      <div class="modern-sub-menu">
        <div class="sub-menu-head">
          <h4>数码产品推荐</h4>
        </div>
        <div class="sub-menu-section">
          <h5>热门标签</h5>
          <div class="option-tags">
            <span class="option-tag">轻薄本</span>
            <span class="option-tag">降噪耳机</span>
            <span class="option-tag">4K 显示器</span>
            <span class="option-tag">机械键盘</span>
          </div>
        </div>
        <div class="sub-menu-section">
          <h5>快速入口</h5>
          <div class="option-grid">
            <div class="option-card">
              <strong>学生装机清单</strong><span>预算 4K-8K</span>
            </div>
            <div class="option-card">
              <strong>办公效率套装</strong><span>显示器 + 扩展坞</span>
            </div>
          </div>
        </div>
      </div>
    </li>
    <li class="menu-item">
      <span class="menu-label">
        <span class="menu-title">家用电器</span>
        <span class="menu-meta">厨房 · 清洁 · 空调</span>
      </span>
      <svg class="chevron" viewBox="0 0 20 20" fill="currentColor"
        ><path
          fill-rule="evenodd"
          d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
          clip-rule="evenodd"></path></svg
      >
      <div class="modern-sub-menu">
        <div class="sub-menu-head">
          <h4>家用电器分类</h4>
        </div>
        <div class="sub-menu-section">
          <h5>热门标签</h5>
          <div class="option-tags">
            <span class="option-tag">一级能效</span>
            <span class="option-tag">母婴净洗</span>
            <span class="option-tag">自清洁空调</span>
            <span class="option-tag">静音冰箱</span>
          </div>
        </div>
        <div class="sub-menu-section">
          <h5>快速入口</h5>
          <div class="option-grid">
            <div class="option-card">
              <strong>新房三件套</strong><span>冰洗空一步到位</span>
            </div>
            <div class="option-card">
              <strong>厨房焕新季</strong><span>烟灶洗组合</span>
            </div>
          </div>
        </div>
      </div>
    </li>
    <li class="menu-item">
      <span class="menu-label">
        <span class="menu-title">图书文娱</span>
        <span class="menu-meta">阅读 · 影视 · 音乐</span>
      </span>
      <svg class="chevron" viewBox="0 0 20 20" fill="currentColor"
        ><path
          fill-rule="evenodd"
          d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
          clip-rule="evenodd"></path></svg
      >
      <div class="modern-sub-menu">
        <div class="sub-menu-head">
          <h4>图书与音像制品</h4>
        </div>
        <div class="sub-menu-section">
          <h5>热门标签</h5>
          <div class="option-tags">
            <span class="option-tag">编程进阶</span>
            <span class="option-tag">推理小说</span>
            <span class="option-tag">黑胶唱片</span>
            <span class="option-tag">纪录片</span>
          </div>
        </div>
        <div class="sub-menu-section">
          <h5>快速入口</h5>
          <div class="option-grid">
            <div class="option-card">
              <strong>技术书精选</strong><span>从入门到项目</span>
            </div>
            <div class="option-card">
              <strong>睡前轻阅读</strong><span>15 分钟短篇</span>
            </div>
          </div>
        </div>
      </div>
    </li>
    <li class="menu-item">
      <span class="menu-label">
        <span class="menu-title">运动户外</span>
        <span class="menu-meta">跑步 · 骑行 · 露营</span>
      </span>
      <svg class="chevron" viewBox="0 0 20 20" fill="currentColor"
        ><path
          fill-rule="evenodd"
          d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
          clip-rule="evenodd"></path></svg
      >
      <div class="modern-sub-menu">
        <div class="sub-menu-head">
          <h4>运动户外装备</h4>
        </div>
        <div class="sub-menu-section">
          <h5>热门标签</h5>
          <div class="option-tags">
            <span class="option-tag">城市慢跑</span>
            <span class="option-tag">越野徒步</span>
            <span class="option-tag">通勤骑行</span>
            <span class="option-tag">周末露营</span>
          </div>
        </div>
        <div class="sub-menu-section">
          <h5>快速入口</h5>
          <div class="option-grid">
            <div class="option-card">
              <strong>跑步新手包</strong><span>鞋 + 表 + 耳机</span>
            </div>
            <div class="option-card">
              <strong>轻量露营包</strong><span>天幕 + 椅 + 炉</span>
            </div>
          </div>
        </div>
      </div>
    </li>
    <li class="menu-item">
      <span class="menu-label">
        <span class="menu-title">家居清洁</span>
        <span class="menu-meta">收纳 · 除菌 · 香氛</span>
      </span>
      <svg class="chevron" viewBox="0 0 20 20" fill="currentColor"
        ><path
          fill-rule="evenodd"
          d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
          clip-rule="evenodd"></path></svg
      >
      <div class="modern-sub-menu">
        <div class="sub-menu-head">
          <h4>家居清洁方案</h4>
        </div>
        <div class="sub-menu-section">
          <h5>热门标签</h5>
          <div class="option-tags">
            <span class="option-tag">扫拖一体</span>
            <span class="option-tag">除螨抑菌</span>
            <span class="option-tag">空间收纳</span>
            <span class="option-tag">空气净化</span>
          </div>
        </div>
        <div class="sub-menu-section">
          <h5>快速入口</h5>
          <div class="option-grid">
            <div class="option-card">
              <strong>春季大扫除</strong><span>客厅卧室全覆盖</span>
            </div>
            <div class="option-card">
              <strong>租房精简套装</strong><span>轻便省空间</span>
            </div>
          </div>
        </div>
      </div>
    </li>
  </ul>
</div>

<style is:global>
  @import "./menu-demo.css";
</style>

<script>
  import { initRawMenu } from "./menu-demo";

  initRawMenu({ containerId: "demo-raw" });
</script>
