---
// src/components/blog/leetcode/TrappingWater.astro
// for leetcode02

const initialHeights = [0, 1, 0, 2, 1, 0, 1, 3, 2, 1, 2, 1];
const maxH = Math.max(...initialHeights, 3);
---

<div class="algo-card font-sans">
  <div class="header">
    <div class="title-area">
      <h3 class="title">双指针：接雨水</h3>
      <div class="score-badge">
        已接雨水: <span id="water-score">0</span> 单位
      </div>
    </div>
    <div class="controls">
      <button id="btn-step" class="btn btn-primary">
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"><path d="M5 3l14 9-14 9V3z"></path></svg
        >
        下一步
      </button>
      <button id="btn-reset" class="btn btn-secondary">
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          ><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"
          ></path><path d="M3 3v5h5"></path></svg
        >
        重置
      </button>
    </div>
  </div>

  <div class="chart-container">
    <div class="chart-core">
      <div id="line-left-max" class="max-line max-line-left"></div>
      <div id="line-right-max" class="max-line max-line-right"></div>
      <span class="line-label label-left" id="label-left-max">Left Max: 0</span>
      <span class="line-label label-right" id="label-right-max"
        >Right Max: 0</span
      >

      <div class="bars-wrapper">
        {
          initialHeights.map((h, i) => (
            <div class="column-wrapper">
              <div class="bar-container">
                <div
                  id={`water-${i}`}
                  class="water-block"
                  style="height: 0%;"
                />
                <div class="solid-bar" style={`height: ${(h / maxH) * 100}%`}>
                  <span class="height-label">{h}</span>
                </div>
              </div>
              <div id={`pointer-${i}`} class="pointer-area" />
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <div class="explanation-box">
    <div class="icon">
      <svg
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="#64748b"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <circle cx="12" cy="12" r="10"></circle>
        <line x1="12" y1="16" x2="12" y2="12"></line>
        <line x1="12" y1="8" x2="12.01" y2="8"></line>
      </svg>
    </div>
    <div class="text" id="explanation-text">
      准备就绪。点击“下一步”观察左右指针如何锁定短板并向中间靠拢。
    </div>
  </div>
</div>

<style>
  /* 基础容器 */
  .algo-card {
    background: #ffffff;
    border-radius: 16px;
    padding: 24px;
    max-width: 800px;
    margin: 0 auto;
    box-shadow:
      0 10px 30px -5px rgba(0, 0, 0, 0.05),
      0 4px 6px -4px rgba(0, 0, 0, 0.02);
    border: 1px solid #f1f5f9;
    color: #0f172a;
  }
  .header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 24px;
  }
  .title {
    margin: 0 0 8px 0;
    font-size: 1.25rem;
    font-weight: 700;
    color: #1e293b;
  }
  .score-badge {
    display: inline-block;
    background: #eff6ff;
    color: #2563eb;
    padding: 4px 12px;
    border-radius: 999px;
    font-size: 0.875rem;
    font-weight: 600;
  }
  .controls {
    display: flex;
    gap: 12px;
  }
  .btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 8px 16px;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    border: none;
    transition: all 0.2s;
  }
  .btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none !important;
  }
  .btn:active:not(:disabled) {
    transform: translateY(1px);
  }
  .btn-primary {
    background: #3b82f6;
    color: white;
    box-shadow: 0 4px 12px rgba(59, 130, 246, 0.2);
  }
  .btn-primary:hover:not(:disabled) {
    background: #2563eb;
  }
  .btn-secondary {
    background: #f8fafc;
    color: #475569;
    border: 1px solid #e2e8f0;
  }
  .btn-secondary:hover {
    background: #f1f5f9;
    color: #0f172a;
  }

  /* 图表可视化区域 */
  .chart-container {
    background: #fafafa;
    border-radius: 12px;
    border: 1px solid #e2e8f0;
    padding: 32px 16px 48px 16px;
    margin-bottom: 20px;
  }
  .chart-core {
    position: relative;
    height: 220px;
    width: 100%;
  }

  .max-line {
    position: absolute;
    left: 0;
    right: 0;
    border-top: 2px dashed;
    opacity: 0;
    transition:
      bottom 0.4s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.3s;
    z-index: 10;
    pointer-events: none;
    bottom: 0%;
  }
  .max-line-left {
    border-color: #ef4444;
  }
  .max-line-right {
    border-color: #10b981;
  }

  .line-label {
    position: absolute;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 2px 6px;
    border-radius: 4px;
    transition:
      bottom 0.4s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.3s;
    z-index: 20;
    opacity: 0;
    pointer-events: none;
    transform: translateY(-8px);
  }
  .label-left {
    left: 0;
    background: #fef2f2;
    color: #ef4444;
    border: 1px solid #fca5a5;
  }
  .label-right {
    right: 0;
    background: #ecfdf5;
    color: #10b981;
    border: 1px solid #6ee7b7;
  }

  .bars-wrapper {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    height: 100%;
    gap: 4px;
    position: absolute;
    inset: 0;
    z-index: 5;
  }
  .column-wrapper {
    flex: 1;
    height: 100%;
    display: flex;
    flex-direction: column;
    position: relative;
  }
  .bar-container {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    position: relative;
  }
  .solid-bar {
    width: 100%;
    background: #475569;
    border-radius: 4px 4px 0 0;
    position: relative;
    box-shadow: inset 0 2px 4px rgba(255, 255, 255, 0.1);
    display: flex;
    justify-content: center;
  }
  .height-label {
    position: absolute;
    top: -20px;
    font-size: 0.75rem;
    color: #94a3b8;
    font-weight: 600;
  }
  .water-block {
    width: 100%;
    background: linear-gradient(
      180deg,
      rgba(96, 165, 250, 0.9) 0%,
      rgba(59, 130, 246, 0.9) 100%
    );
    border-radius: 2px 2px 0 0;
    transition: height 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: inset 0 2px 6px rgba(255, 255, 255, 0.3);
  }

  /* 指针气泡样式 */
  .pointer-area {
    position: absolute;
    bottom: -37px;
    left: 0;
    right: 0;
    display: flex;
    justify-content: center;
    z-index: 20;
    pointer-events: none;
  }

  /* 气泡徽章主体 */
  .ptr-badge {
    position: relative;
    font-size: 0.8rem;
    font-weight: 800;
    color: white;
    padding: 2px 10px;
    border-radius: 8px;
    box-shadow:
      0 4px 6px -1px rgba(0, 0, 0, 0.15),
      0 2px 4px -1px rgba(0, 0, 0, 0.1);
    animation: float 2s ease-in-out infinite;
    margin-top: 6px;
  }

  /* 气泡顶部小三角 */
  .ptr-badge::before {
    content: "";
    position: absolute;
    top: -5px;
    left: 50%;
    transform: translateX(-50%);
    border-width: 0 5px 6px 5px;
    border-style: solid;
  }

  /* L/R 颜色配置 */
  .ptr-badge-l {
    background: #ef4444;
  }
  .ptr-badge-l::before {
    border-color: transparent transparent #ef4444 transparent;
  }

  .ptr-badge-r {
    background: #10b981;
  }
  .ptr-badge-r::before {
    border-color: transparent transparent #10b981 transparent;
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-3px);
    }
  }

  /* 说明文字区域 */
  .explanation-box {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    padding: 16px;
    border-radius: 12px;
  }
  .explanation-box .icon {
    margin-top: 2px;
    flex-shrink: 0;
  }
  .explanation-box .text {
    color: #334155;
    font-size: 0.95rem;
    line-height: 1.5;
    margin: 0;
  }

  /* 移动端适配 */
  @media (max-width: 640px) {
    .algo-card {
      padding: 4px 16px;
    }
    .header {
      flex-direction: column;
      align-items: stretch;
      gap: 8px;
      margin-bottom: 4px;
    }
    .title-area {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 4px;
      width: 100%;
    }
    .title {
      margin: 0;
      font-size: 1.15rem;
    }
    .score-badge {
      white-space: nowrap;
      padding: 6px 10px;
      font-size: 0.8rem;
    }
    .controls {
      width: 100%;
      justify-content: space-between;
      gap: 8px;
    }
    .btn {
      flex: 1;
      padding: 6px 8px;
      font-size: 0.85rem;
      height: 36px;
    }
    .chart-container {
      padding: 20px 4px 32px 4px;
      margin-top: 12px;
      margin-bottom: 12px;
    }
    .chart-core {
      height: 160px;
    }
    .bars-wrapper {
      gap: 1px;
    }
    .height-label {
      font-size: 0.6rem;
      top: -16px;
    }
    .line-label {
      font-size: 0.65rem;
      padding: 1px 4px;
    }

    .pointer-area {
      bottom: -31px;
    }
    .ptr-badge {
      font-size: 0.7rem;
      padding: 2px 8px;
      border-radius: 6px;
      margin-top: 5px;
    }
    .ptr-badge::before {
      top: -4px;
      border-width: 0 4px 5px 4px;
    }

    .explanation-box {
      padding: 10px 12px;
      align-items: center;
      margin-bottom: 12px;
    }
    .explanation-box .text {
      font-size: 0.8rem;
      line-height: 1.35;
    }
  }
</style>

<script define:vars={{ initialHeights, maxH }}>
  let left = 0;
  let right = initialHeights.length - 1;
  let leftMax = 0;
  let rightMax = 0;
  let totalWater = 0;
  let isFinished = false;

  const btnStep = document.getElementById("btn-step");
  const btnReset = document.getElementById("btn-reset");
  const scoreEl = document.getElementById("water-score");
  const expEl = document.getElementById("explanation-text");

  const lineLeftMax = document.getElementById("line-left-max");
  const lineRightMax = document.getElementById("line-right-max");
  const labelLeftMax = document.getElementById("label-left-max");
  const labelRightMax = document.getElementById("label-right-max");

  /**
   * 更新指针位置及最大高度参考线
   */
  function updateVisuals() {
    // 更新 L/R 指针 DOM
    for (let i = 0; i < initialHeights.length; i++) {
      const p = document.getElementById(`pointer-${i}`);
      if (!p) continue;
      if (i === left) {
        p.innerHTML = '<div class="ptr-badge ptr-badge-l">L</div>';
      } else if (i === right) {
        p.innerHTML = '<div class="ptr-badge ptr-badge-r">R</div>';
      } else {
        p.innerHTML = "";
      }
    }

    let leftOffset = 0;
    let rightOffset = 0;

    // 处理左右最大高度重合时的视觉偏移
    if (leftMax === rightMax && leftMax > 0) {
      leftOffset = 2;
      rightOffset = -2;
    }

    // 绘制左侧最大高度线
    if (leftMax > 0) {
      lineLeftMax.style.opacity = "1";
      labelLeftMax.style.opacity = "1";
      const bottomStr = `calc(${(leftMax / maxH) * 100}% + ${leftOffset}px)`;
      lineLeftMax.style.bottom = bottomStr;
      labelLeftMax.style.bottom = bottomStr;
      labelLeftMax.innerText = `Left Max: ${leftMax}`;
    } else {
      lineLeftMax.style.opacity = "0";
      labelLeftMax.style.opacity = "0";
    }

    // 绘制右侧最大高度线
    if (rightMax > 0) {
      lineRightMax.style.opacity = "1";
      labelRightMax.style.opacity = "1";
      const bottomStr = `calc(${(rightMax / maxH) * 100}% + ${rightOffset}px)`;
      lineRightMax.style.bottom = bottomStr;
      labelRightMax.style.bottom = bottomStr;
      labelRightMax.innerText = `Right Max: ${rightMax}`;
    } else {
      lineRightMax.style.opacity = "0";
      labelRightMax.style.opacity = "0";
    }
  }

  /**
   * 执行一步双指针算法逻辑
   */
  function stepForward() {
    if (left >= right) {
      isFinished = true;
      btnStep.disabled = true;
      expEl.innerHTML =
        "<strong>演示结束！</strong> 左右指针相遇，接雨水总量计算完毕。";
      updateVisuals();
      return;
    }

    let currentWater = 0;
    let actionText = "";

    // 更新当前两端的最大高度
    leftMax = Math.max(leftMax, initialHeights[left]);
    rightMax = Math.max(rightMax, initialHeights[right]);

    // 核心策略：移动短的一端
    if (leftMax < rightMax) {
      currentWater = leftMax - initialHeights[left];
      if (currentWater > 0) {
        document.getElementById(`water-${left}`).style.height =
          `${(currentWater / maxH) * 100}%`;
      }
      actionText = `左侧最大值 <span style="color:#ef4444;font-weight:bold;">${leftMax}</span> < 右侧最大值 <span style="color:#10b981;font-weight:bold;">${rightMax}</span>。左侧短板，计算 L 处水量: ${leftMax} - ${initialHeights[left]} = <strong>${currentWater}</strong>，L 向右移。`;
      left++;
    } else {
      currentWater = rightMax - initialHeights[right];
      if (currentWater > 0) {
        document.getElementById(`water-${right}`).style.height =
          `${(currentWater / maxH) * 100}%`;
      }
      actionText = `左侧最大值 <span style="color:#ef4444;font-weight:bold;">${leftMax}</span> ≥ 右侧最大值 <span style="color:#10b981;font-weight:bold;">${rightMax}</span>。右侧短板，计算 R 处水量: ${rightMax} - ${initialHeights[right]} = <strong>${currentWater}</strong>，R 向左移。`;
      right--;
    }

    totalWater += currentWater;
    scoreEl.innerText = totalWater;
    expEl.innerHTML = actionText;
    updateVisuals();
  }

  /**
   * 重置演示状态
   */
  function reset() {
    left = 0;
    right = initialHeights.length - 1;
    leftMax = 0;
    rightMax = 0;
    totalWater = 0;
    isFinished = false;
    btnStep.disabled = false;
    scoreEl.innerText = "0";
    expEl.innerHTML =
      "准备就绪。点击“下一步”观察左右指针如何锁定短板并向中间靠拢。";

    for (let i = 0; i < initialHeights.length; i++) {
      const w = document.getElementById(`water-${i}`);
      if (w) w.style.height = "0%";
    }
    updateVisuals();
  }

  btnStep.addEventListener("click", stepForward);
  btnReset.addEventListener("click", reset);
  updateVisuals();
</script>
