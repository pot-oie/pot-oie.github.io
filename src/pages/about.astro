---
// src/pages/about.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";

const pageTitle = "About Me";
const pageDescription = "关于 Pot 的一些介绍。";

// 技术栈列表
const techStack = [
  "C++",
  "Java",
  "Kotlin",
  "JS / TS",
  "Vue",
  "Astro",
  "Flutter",
  "Qt",
  "Python",
  "Waiting to fill...",
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <section class="py-8 md:py-16 px-4 max-w-3xl mx-auto">
    {/* --- 头部：大标题与格言 --- */}
    <div
      class="mb-8 md:mb-12 border-b border-ink-900 dark:border-zinc-700 pb-8 transition-colors"
    >
      <h1
        class="text-5xl md:text-7xl font-serif font-bold text-ink-900 dark:text-zinc-100 mb-6 tracking-tight transition-colors"
      >
        About
      </h1>
      <p
        class="text-xl text-ink-500 dark:text-zinc-400 font-serif italic transition-colors"
      >
        "Stay hungry, stay foolish." {/* [留空] */}
      </p>
    </div>

    {/* --- 正文区域 --- */}
    <div class="prose prose-ink">
      {/* 简介 */}
      <h2
        class="flex flex-wrap items-center gap-x-3 gap-y-1 mt-10 md:mt-14 leading-tight"
      >
        <Icon name="mingcute:user-3-line" class="w-6 h-6 text-vermilion" />
        <span>Who am I / 我是谁</span>
      </h2>
      <p class="mb-6 text-ink-700 dark:text-zinc-300">
        你好，我是桂圆子。
        <br />
        一名正在学习的大三学生。
      </p>

      {/* Timeline 时间轴 */}
      <h2
        class="flex flex-wrap items-center gap-x-3 gap-y-1 mt-10 md:mt-14 leading-tight"
      >
        <Icon name="mingcute:time-line" class="w-6 h-6 text-vermilion" />
        <span>Timeline / 时间轴</span>
      </h2>

      <div
        class="relative border-l border-ink-200 dark:border-zinc-800 ml-3 space-y-12 pb-4 pt-2"
      >
        {/* 2026 (Current) */}
        <div class="relative pl-8 group">
          <div
            class="absolute -left-[6.5px] top-2 w-3.5 h-3.5 rounded-full bg-vermilion shadow-[0_0_0_4px_var(--bg-body)] transition-colors"
          >
          </div>

          <div
            class="flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-4"
          >
            <span
              class="font-bold text-2xl text-ink-900 dark:text-zinc-100 font-serif group-hover:text-vermilion transition-colors"
              >2026</span
            >
            <span
              class="text-xs font-bold font-sans tracking-widest text-vermilion uppercase bg-vermilion/10 px-2 py-0.5 rounded-sm self-start sm:self-auto"
              >Current</span
            >
          </div>
          <p
            class="mt-3 text-ink-700 dark:text-zinc-300 m-0 text-base leading-relaxed"
          >
            完善博客，并刷 LeetCode 提升编程能力。
          </p>
        </div>

        <div class="relative pl-8 group">
          <div
            class="absolute -left-[5px] top-2.5 w-2.5 h-2.5 rounded-full bg-ink-300 dark:bg-zinc-600 shadow-[0_0_0_4px_var(--bg-body)] transition-colors group-hover:bg-ink-500 dark:group-hover:bg-zinc-400"
          >
          </div>

          <span
            class="font-bold text-xl text-ink-900 dark:text-zinc-100 font-serif group-hover:text-ink-600 dark:group-hover:text-zinc-300 transition-colors"
            >2025</span
          >
          <p
            class="mt-2 text-ink-700 dark:text-zinc-300 m-0 text-base leading-relaxed"
          >
            搭建博客，并积极尝试各类语言开发。
          </p>
        </div>
      </div>

      {/* Now 近况 */}
      <h2
        class="flex flex-wrap items-center gap-x-3 gap-y-1 mt-10 md:mt-14 leading-tight"
      >
        <Icon
          name="mingcute:location-line"
          class="w-6 h-6 text-vermilion shrink-0"
        />
        <span>Now / 近况</span>
      </h2>
      <p class="mb-6 text-ink-700 dark:text-zinc-300">目前我专注于：</p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-3 not-prose">
        {/* 卡片 1 */}
        <div
          class="p-3 rounded-sm border border-ink-200 dark:border-zinc-700 bg-white dark:bg-zinc-800/50 flex items-start gap-3 transition-all hover:shadow-ink hover:-translate-y-1"
        >
          <Icon
            name="mingcute:book-2-line"
            class="w-5 h-5 text-vermilion mt-2 ml-2 shrink-0"
          />
          <div>
            <h4
              class="font-bold text-ink-900 dark:text-zinc-100 text-sm mb-1 mt-2!"
            >
              正在学习
            </h4>
            <p class="text-ink-600 dark:text-zinc-400 text-sm m-0 mb-2!">
              leetcode & 408
            </p>
          </div>
        </div>

        {/* 卡片 2 */}
        <div
          class="p-3 rounded-sm border border-ink-200 dark:border-zinc-700 bg-white dark:bg-zinc-800/50 flex items-start gap-3 transition-all hover:shadow-ink hover:-translate-y-1"
        >
          <Icon
            name="mingcute:book-5-line"
            class="w-5 h-5 text-vermilion mt-2 ml-2 shrink-0"
          />
          <div>
            <h4
              class="font-bold text-ink-900 dark:text-zinc-100 text-sm mb-1 mt-2!"
            >
              正在阅读
            </h4>
            <p class="text-ink-600 dark:text-zinc-400 text-sm m-0 mb-2!">
              1367
            </p>
          </div>
        </div>

        {/* 卡片 3 */}
        <div
          class="p-3 rounded-sm border border-ink-200 dark:border-zinc-700 bg-white dark:bg-zinc-800/50 flex items-start gap-3 transition-all hover:shadow-ink hover:-translate-y-1"
        >
          <Icon
            name="mingcute:code-line"
            class="w-5 h-5 text-vermilion mt-2 ml-2 shrink-0"
          />
          <div>
            <h4
              class="font-bold text-ink-900 dark:text-zinc-100 text-sm mb-1 mt-2!"
            >
              正在开发
            </h4>
            <p class="text-ink-600 dark:text-zinc-400 text-sm m-0 mb-2!">
              个人博客
            </p>
          </div>
        </div>
      </div>

      {/* Tech Stack */}
      <h2
        class="flex flex-wrap items-center gap-x-3 gap-y-1 mt-10 md:mt-14 leading-tight"
      >
        <Icon
          name="mingcute:terminal-box-line"
          class="w-6 h-6 text-vermilion shrink-0"
        />
        <span>Tech Stack / 技术栈</span>
      </h2>
      <div class="flex flex-wrap gap-3 not-prose mt-6">
        {
          techStack.map((tech) => (
            <span class="px-3 py-1.5 text-sm font-sans border border-ink-200 dark:border-zinc-700 rounded-sm text-ink-700 dark:text-zinc-300 bg-ink-50 dark:bg-zinc-800/50 transition-colors select-none hover:border-vermilion hover:text-vermilion dark:hover:text-vermilion cursor-default">
              {tech}
            </span>
          ))
        }
      </div>

      {/* Connect */}
      <h2
        class="flex flex-wrap items-center gap-x-3 gap-y-1 mt-10 md:mt-14 leading-tight"
      >
        <Icon
          name="mingcute:send-plane-line"
          class="w-6 h-6 text-vermilion shrink-0"
        />
        <span>Connect / 联系</span>
      </h2>
      <p class="mb-6 text-ink-700 dark:text-zinc-300">
        你可以通过以下方式找到我：
      </p>

      <ul class="connect-list list-none pl-0 space-y-4 not-prose">
        {/* 列表项 1 */}
        <li
          class="flex items-center gap-4 p-3 border-b border-ink-200 dark:border-zinc-800 overflow-hidden"
        >
          <Icon
            name="mingcute:github-fill"
            class="w-6 h-6 text-ink-400 dark:text-zinc-500 shrink-0"
          />
          <div class="flex flex-col min-w-0 flex-1">
            <span
              class="text-xs text-ink-400 dark:text-zinc-500 uppercase tracking-wider"
              >GitHub</span
            >
            <a
              href="https://github.com/pot-oie"
              target="_blank"
              class="text-ink-900 dark:text-zinc-100 font-bold truncate block hover:text-vermilion transition-colors"
            >
              pot-oie
            </a>
          </div>
        </li>

        {/* 列表项 2 */}
        <li
          class="flex items-center gap-4 p-3 border-b border-ink-200 dark:border-zinc-800 overflow-hidden"
        >
          <Icon
            name="mingcute:mail-ai-fill"
            class="w-6 h-6 text-ink-400 dark:text-zinc-500 shrink-0"
          />
          <div class="flex flex-col min-w-0 flex-1">
            <span
              class="text-xs text-ink-400 dark:text-zinc-500 uppercase tracking-wider"
              >Email</span
            >
            {/* 关键类：overflow-x-auto scrollbar-hide whitespace-nowrap */}
            <a
              href="mailto:pooot1110@gmail.com"
              class="text-ink-900 dark:text-zinc-100 font-bold block hover:text-vermilion transition-colors overflow-x-auto scrollbar-hide whitespace-nowrap"
            >
              pooot1110@gmail.com
            </a>
          </div>
        </li>

        {/* 列表项 3 */}
        <li
          class="relative flex items-center gap-4 p-3 border-b border-ink-200 dark:border-zinc-800 overflow-visible"
        >
          <Icon
            name="mingcute:wechat-fill"
            class="w-6 h-6 text-ink-400 dark:text-zinc-500 shrink-0"
          />
          <div class="flex flex-col min-w-0 flex-1">
            <span
              class="text-xs text-ink-400 dark:text-zinc-500 uppercase tracking-wider"
              >WeChat</span
            >
            <div class="qr-wrapper not-prose inline-block">
              <div class="relative w-fit group/qr not-prose">
                <button
                  type="button"
                  class="text-ink-900 dark:text-zinc-100 font-bold select-all block text-left hover:text-vermilion transition-colors focus:outline-none"
                  aria-label="显示微信二维码"
                >
                  pot-oie
                </button>

                <div
                  class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 bg-white dark:bg-zinc-800 backdrop-blur-sm rounded-xl shadow-xl border border-ink-100/5 transition-all duration-300 opacity-0 translate-y-2 scale-95 pointer-events-none group-hover/qr:opacity-100 group-hover/qr:translate-y-0 group-hover/qr:scale-100 group-hover/qr:pointer-events-auto group-focus-within/qr:opacity-100 group-focus-within/qr:translate-y-0 group-focus-within/qr:scale-100 group-focus-within/qr:pointer-events-auto w-44 z-20"
                >
                  <div
                    class="bg-white rounded-md shadow-sm w-full aspect-square overflow-hidden"
                  >
                    <img
                      src="/docs/wechat-qr.png"
                      alt="微信添加好友二维码"
                      class="block w-full h-full object-cover object-top"
                      style="margin:0"
                      loading="lazy"
                    />
                  </div>

                  <div
                    class="absolute top-full left-1/2 -translate-x-1/2 border-8 border-transparent border-t-white dark:border-t-zinc-800"
                  >
                  </div>
                </div>
              </div>
            </div>
          </div>
        </li>
      </ul>

      {/* 滚动条 */}
      <style>
        .prose-ink .connect-list,
        .prose-ink .connect-list li {
          margin: 0;
          padding-left: 0;
        }

        .prose-ink .connect-list > li::before {
          content: none;
        }

        .scrollbar-hide::-webkit-scrollbar {
          display: none;
        }
        .scrollbar-hide {
          -ms-overflow-style: none;
          scrollbar-width: none;
        }
      </style>
    </div>
  </section>
</BaseLayout>
