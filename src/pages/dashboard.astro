---
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle = "Dashboard";
const pageDescription = "Search metrics dashboard";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Fragment slot="head">
    <meta name="robots" content="noindex,nofollow,noarchive" />
  </Fragment>

  <section class="py-8 md:py-14">
    <header class="mb-8 border-b border-ink-900 dark:border-zinc-700 pb-6">
      <p
        class="text-xs uppercase tracking-[0.18em] text-ink-400 dark:text-zinc-500"
      >
        Private view
      </p>
      <h1
        class="mt-2 text-4xl md:text-5xl font-serif font-bold text-ink-900 dark:text-zinc-100"
      >
        Search Dashboard
      </h1>
      <p class="mt-3 text-sm text-ink-500 dark:text-zinc-400">
        Data source: localStorage key <code>pot-search-metrics-v1</code>
      </p>
    </header>

    <div
      id="metrics-empty"
      class="hidden border border-dashed border-ink-300 dark:border-zinc-700 rounded px-4 py-5 text-sm text-ink-500 dark:text-zinc-400"
    >
      暂无统计数据。先在站内触发几次搜索再刷新此页。
    </div>

    <div id="metrics-content" class="hidden space-y-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <article
          class="rounded border border-ink-200 dark:border-zinc-700 bg-white/70 dark:bg-zinc-900/40 p-4"
        >
          <p
            class="text-xs uppercase tracking-[0.14em] text-ink-400 dark:text-zinc-500"
          >
            Total events
          </p>
          <p
            id="kpi-total"
            class="mt-2 text-2xl font-serif font-bold text-ink-900 dark:text-zinc-100"
          >
            0
          </p>
        </article>
        <article
          class="rounded border border-ink-200 dark:border-zinc-700 bg-white/70 dark:bg-zinc-900/40 p-4"
        >
          <p
            class="text-xs uppercase tracking-[0.14em] text-ink-400 dark:text-zinc-500"
          >
            No-result rate
          </p>
          <p
            id="kpi-no-result-rate"
            class="mt-2 text-2xl font-serif font-bold text-ink-900 dark:text-zinc-100"
          >
            0%
          </p>
        </article>
        <article
          class="rounded border border-ink-200 dark:border-zinc-700 bg-white/70 dark:bg-zinc-900/40 p-4"
        >
          <p
            class="text-xs uppercase tracking-[0.14em] text-ink-400 dark:text-zinc-500"
          >
            Avg. duration
          </p>
          <p
            id="kpi-duration"
            class="mt-2 text-2xl font-serif font-bold text-ink-900 dark:text-zinc-100"
          >
            0 ms
          </p>
        </article>
        <article
          class="rounded border border-ink-200 dark:border-zinc-700 bg-white/70 dark:bg-zinc-900/40 p-4"
        >
          <p
            class="text-xs uppercase tracking-[0.14em] text-ink-400 dark:text-zinc-500"
          >
            Summary trimmed
          </p>
          <p
            id="kpi-trimmed"
            class="mt-2 text-2xl font-serif font-bold text-ink-900 dark:text-zinc-100"
          >
            0
          </p>
        </article>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <section class="rounded border border-ink-200 dark:border-zinc-700 p-4">
          <h2 class="text-base font-bold text-ink-900 dark:text-zinc-100">
            Event breakdown
          </h2>
          <ul
            id="event-breakdown"
            class="mt-4 space-y-2 text-sm text-ink-600 dark:text-zinc-300"
          >
          </ul>
        </section>

        <section class="rounded border border-ink-200 dark:border-zinc-700 p-4">
          <h2 class="text-base font-bold text-ink-900 dark:text-zinc-100">
            Top no-result queries
          </h2>
          <ul
            id="no-result-list"
            class="mt-4 space-y-2 text-sm text-ink-600 dark:text-zinc-300"
          >
          </ul>
        </section>
      </div>

      <section class="rounded border border-ink-200 dark:border-zinc-700 p-4">
        <h2 class="text-base font-bold text-ink-900 dark:text-zinc-100">
          Recent events
        </h2>
        <div class="mt-4 overflow-auto">
          <table class="min-w-full text-sm text-left">
            <thead>
              <tr
                class="border-b border-ink-200 dark:border-zinc-700 text-ink-500 dark:text-zinc-400"
              >
                <th class="py-2 pr-4">Time</th>
                <th class="py-2 pr-4">Event</th>
                <th class="py-2 pr-4">Query</th>
                <th class="py-2 pr-4">Duration</th>
                <th class="py-2 pr-4">Shown</th>
              </tr>
            </thead>
            <tbody id="recent-events" class="text-ink-700 dark:text-zinc-200"
            ></tbody>
          </table>
        </div>
      </section>

      <div class="flex items-center gap-3">
        <button
          id="refresh-btn"
          class="px-4 py-2 text-xs uppercase tracking-[0.14em] border border-ink-300 dark:border-zinc-600 text-ink-600 dark:text-zinc-300 hover:text-vermilion hover:border-vermilion transition-colors"
        >
          Refresh
        </button>
        <button
          id="clear-btn"
          class="px-4 py-2 text-xs uppercase tracking-[0.14em] border border-ink-300 dark:border-zinc-600 text-ink-600 dark:text-zinc-300 hover:text-vermilion hover:border-vermilion transition-colors"
        >
          Clear
        </button>
        <p id="updated-at" class="text-xs text-ink-400 dark:text-zinc-500"></p>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // @ts-nocheck
  function getStore() {
    const api = window.__potSearchMetrics;
    if (api && typeof api.read === "function") return api.read();

    const raw = window.localStorage.getItem("pot-search-metrics-v1");
    if (!raw) return null;

    try {
      return JSON.parse(raw);
    } catch {
      return null;
    }
  }

  function getEl(id) {
    return document.getElementById(id);
  }

  function toArrayEntries(record) {
    if (!record || typeof record !== "object") return [];
    return Object.entries(record).sort((a, b) => Number(b[1]) - Number(a[1]));
  }

  function formatTime(timestamp) {
    if (!timestamp) return "-";
    const d = new Date(timestamp);
    if (Number.isNaN(d.getTime())) return "-";
    return d.toLocaleString("zh-CN", { hour12: false });
  }

  function renderDashboard() {
    const store = getStore();

    const empty = getEl("metrics-empty");
    const content = getEl("metrics-content");
    if (!empty || !content) return;

    if (!store || !store.total) {
      empty.classList.remove("hidden");
      content.classList.add("hidden");
      return;
    }

    empty.classList.add("hidden");
    content.classList.remove("hidden");

    const successCount = Number(store.byEvent?.search_success || 0);
    const noResultCount = Number(store.byEvent?.search_no_results || 0);
    const noResultRate =
      successCount > 0
        ? ((noResultCount / successCount) * 100).toFixed(1)
        : "0.0";

    const recent = Array.isArray(store.recent) ? store.recent : [];
    const recentSuccess = recent.filter(
      (item) => item?.event === "search_success",
    );

    const durationList = recentSuccess
      .map((item) => Number(item?.payload?.durationMs || 0))
      .filter((n) => Number.isFinite(n) && n > 0);

    const avgDuration =
      durationList.length > 0
        ? Math.round(
            durationList.reduce((a, b) => a + b, 0) / durationList.length,
          )
        : 0;

    const summaryTrimmed = recentSuccess.reduce((sum, item) => {
      const value = Number(item?.payload?.summaryTrimmed || 0);
      return sum + (Number.isFinite(value) ? value : 0);
    }, 0);

    const totalEl = getEl("kpi-total");
    const noResultRateEl = getEl("kpi-no-result-rate");
    const durationEl = getEl("kpi-duration");
    const trimmedEl = getEl("kpi-trimmed");
    if (!totalEl || !noResultRateEl || !durationEl || !trimmedEl) return;

    totalEl.textContent = String(store.total || 0);
    noResultRateEl.textContent = `${noResultRate}%`;
    durationEl.textContent = `${avgDuration} ms`;
    trimmedEl.textContent = String(summaryTrimmed);

    const eventsList = getEl("event-breakdown");
    if (!eventsList) return;
    eventsList.innerHTML = "";
    toArrayEntries(store.byEvent || {}).forEach(([name, count]) => {
      const li = document.createElement("li");
      li.textContent = `${name}: ${count}`;
      eventsList.appendChild(li);
    });

    const noResultList = getEl("no-result-list");
    if (!noResultList) return;
    noResultList.innerHTML = "";
    const noResultQueries = Array.isArray(store.noResultQueries)
      ? store.noResultQueries
      : [];

    if (noResultQueries.length === 0) {
      const li = document.createElement("li");
      li.textContent = "(暂无)";
      noResultList.appendChild(li);
    } else {
      noResultQueries.slice(0, 10).forEach((query) => {
        const li = document.createElement("li");
        li.textContent = query;
        noResultList.appendChild(li);
      });
    }

    const recentBody = getEl("recent-events");
    if (!recentBody) return;
    recentBody.innerHTML = "";

    recent.slice(0, 25).forEach((row) => {
      const tr = document.createElement("tr");
      tr.className = "border-b border-ink-100 dark:border-zinc-800";

      const query =
        typeof row?.payload?.query === "string"
          ? String(row.payload.query)
          : "-";
      const duration =
        row?.event === "search_success" && row?.payload?.durationMs != null
          ? `${row.payload.durationMs} ms`
          : "-";
      const shown =
        row?.event === "search_success" && row?.payload?.shown != null
          ? String(row.payload.shown)
          : "-";

      tr.innerHTML = `
        <td class="py-2 pr-4 whitespace-nowrap">${formatTime(row?.timestamp || 0)}</td>
        <td class="py-2 pr-4">${row?.event || "-"}</td>
        <td class="py-2 pr-4">${query}</td>
        <td class="py-2 pr-4 whitespace-nowrap">${duration}</td>
        <td class="py-2 pr-4">${shown}</td>
      `;
      recentBody.appendChild(tr);
    });

    const updated = getEl("updated-at");
    if (updated)
      updated.textContent = `Updated: ${formatTime(store.updatedAt)}`;
  }

  function initDashboard() {
    renderDashboard();

    getEl("refresh-btn")?.addEventListener("click", () => {
      renderDashboard();
    });

    getEl("clear-btn")?.addEventListener("click", () => {
      if (window.__potSearchMetrics?.clear) {
        window.__potSearchMetrics.clear();
      } else {
        window.localStorage.removeItem("pot-search-metrics-v1");
      }
      renderDashboard();
    });
  }

  document.addEventListener("astro:page-load", initDashboard);
</script>
